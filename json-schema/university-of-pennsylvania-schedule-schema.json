      "maxLength": 255
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    }
  },
  "required": [
    "sections",
    "name"
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
